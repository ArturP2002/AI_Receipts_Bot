# Токен от @BotFather
BOT_TOKEN=

# Список user_id админов через запятую (для админ-функций)
ADMIN_USER_IDS=

# Username бота без @ — реферальные ссылки и тексты (config.py)
BOT_USERNAME=

# -----------------------------------------------------------------------------
# Telegram Stars — цены и подписка (config.py)
# -----------------------------------------------------------------------------
RECIPE_STAR_PRICE=1
SHOW_MORE_STAR_PRICE=10

SUBSCRIPTION_DEFAULT_DAYS=30
SUBSCRIPTION_STAR_PRICE=1
SUBSCRIPTION_POST_EXPIRY_REMIND_DAYS=3

OPENAI_API_KEY=

OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_IMAGE_SIZE=1024x1024

# -----------------------------------------------------------------------------
# Подбор по продуктам + ИИ (handlers/products.py, config.py)
# off | fallback | always
PRODUCTS_AI_MODE=fallback

# Кухни мира (handlers/cuisines.py): off | fallback | always
CUISINES_AI_MODE=always

AI_RECIPES_PER_REQUEST=3

# -----------------------------------------------------------------------------
# Ежедневная рассылка «Рецепт дня» (services/daily_recipe.py)
# -----------------------------------------------------------------------------
DAILY_RECIPE_ENABLED=on
DAILY_RECIPE_HOUR_MSK=16
DAILY_RECIPE_MINUTE_MSK=0
DAILY_RECIPE_SEND_WINDOW_MINUTES=10

# -----------------------------------------------------------------------------
# Логирование (logging_config.py)
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Данные mini app
ADMIN_WEBAPP_PUBLIC_URL=
ADMIN_WEBAPP_HOST=0.0.0.0
ADMIN_WEBAPP_PORT=8765
